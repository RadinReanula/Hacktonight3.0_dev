# ---------------------------------------------------------------------------
# Database connection (used by lib/db.ts via `pg`).
# Pick ONE of the two options below.
# ---------------------------------------------------------------------------

# Option A — Supabase (hosted Postgres). RECOMMENDED for the team.
# Supabase → "Connect" button → Session pooler (port 5432) or Direct, NOT the
# transaction pooler (6543): the app runs multi-statement transactions
# (transfers, bills). SSL is enabled automatically in lib/db.ts for supabase
# hosts. Do NOT append `?sslmode=require` — newer `pg` treats it as strict
# verify-full and rejects Supabase's cert chain.
#   DATABASE_URL=postgresql://postgres.[project-ref]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Option B — Local / Docker Postgres (default `db` service in compose.yml).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecurepassword
POSTGRES_DB=htn26db
DATABASE_URL=postgresql://postgres:supersecurepassword@db:5432/htn26db

# ---------------------------------------------------------------------------
# Secret used to sign session JWTs (lib/session.ts).
# REQUIRED in production. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------------
SESSION_SECRET=change-me-to-a-long-random-string-min-16-chars
