# Postgres (used by the `db` service in compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecurepassword
POSTGRES_DB=htn26db

# Connection string used by the app (lib/db.ts).
# Inside Docker Compose the host is the service name `db` on port 5432.
# Postgres is not published to the host by default (Windows port-range conflicts).
DATABASE_URL=postgresql://postgres:supersecurepassword@db:5432/htn26db

# Secret used to sign session JWTs (lib/session.ts).
# REQUIRED in production. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string-min-16-chars

# Resend email (lib/email/*)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
APP_BASE_URL=http://localhost:3001
EMAIL_VERIFY_TTL_HOURS=24
EMAIL_DISABLE_SEND=false
