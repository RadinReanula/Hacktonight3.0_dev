{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**",
      "!**/*.mjs"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": false
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2,
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "none"
    }
  },
  "json": {
    "formatter": {
      "enabled": false
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "enabled": true
  },
  "overrides": [
    {
      "includes": [
        "app/bank-accounts/page.tsx",
        "app/bank-transfer/page.tsx",
        "app/pay-bills/page.tsx",
        "app/dashboard/page.tsx",
        "app/e-statement/page.tsx",
        "components/sidebar.tsx",
        "components/Icons.tsx",
        "components/authButton.tsx"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "useButtonType": "warn",
            "noSvgWithoutTitle": "warn",
            "noLabelWithoutControl": "warn",
            "noStaticElementInteractions": "warn",
            "useKeyWithClickEvents": "warn"
          },
          "suspicious": {
            "noArrayIndexKey": "warn"
          }
        }
      }
    }
  ]
}
